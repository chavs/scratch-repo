import React, { useState } from 'react';
import { 
  ArrowRight, 
  CheckCircle, 
  BarChart2, 
  Download, 
  Shield, 
  Zap, 
  Layout, 
  ChevronRight, 
  RefreshCw, 
  Layers 
} from 'lucide-react';

/**
 * DATA & CONFIGURATION
 * Logic sourced from Cloudflare App Innovation Report 2026
 */

const QUESTIONS = [
  {
    id: 's_mod_perception',
    category: 'Strategy',
    question: "Thinking about your organization’s application modernization efforts as a whole, which best describes your timing?",
    options: [
      { id: 'ahead', label: "Ahead of schedule", value: 'leader' },
      { id: 'on_schedule', label: "On schedule", value: 'average' },
      { id: 'behind', label: "Behind schedule", value: 'laggard' }
    ]
  },
  {
    id: 's_mod_dm',
    category: 'Agility',
    question: "How would you describe your organization’s decision-making process regarding app infrastructure modernization?",
    options: [
      { id: 'streamlined', label: "Streamlined (Few decision makers)", score: 10 },
      { id: 'fractured', label: "Fractured (Many decision makers)", score: 0 },
      { id: 'siloed', label: "Siloed / Disconnected", score: 0 }
    ]
  },
  {
    id: 'm_mod_challenges',
    category: 'Challenges',
    question: "What is your primary challenge in modernizing application environments?",
    options: [
      { id: 'complexity', label: "Implementation complexity (multiple vendors)", score: 0 },
      { id: 'skills', label: "Skills gap / Resource constraints", score: 5 },
      { id: 'budget', label: "Budget limitations", score: 5 },
      { id: 'none', label: "No significant challenges", score: 10 }
    ]
  },
  {
    id: 's_techstack_effort',
    category: 'Consolidation',
    question: "How much effort has your organization put into technology stack consolidation over the past 12 months?",
    options: [
      { id: 'high', label: "A lot of effort", score: 10 },
      { id: 'moderate', label: "Some effort", score: 5 },
      { id: 'low', label: "Little to no effort", score: 0 }
    ]
  },
  {
    id: 's_sec_difficulty',
    category: 'Security',
    question: "How easy or difficult is it to align your organization’s security efforts with application modernization?",
    options: [
      { id: 'easy', label: "Very Easy", score: 10 },
      { id: 'somewhat_easy', label: "Somewhat Easy", score: 5 },
      { id: 'difficult', label: "Difficult", score: 0 }
    ]
  },
  {
    id: 's_sec_compliance',
    category: 'Security',
    question: "How easy is it to balance speed to market versus system reliability?",
    options: [
      { id: 'easy', label: "Easy to balance", score: 10 },
      { id: 'neutral', label: "Neutral", score: 5 },
      { id: 'hard', label: "Hard / Trade-offs required", score: 0 }
    ]
  },
  {
    id: 's_ai_mod',
    category: 'AI Readiness',
    question: "How has app modernization impacted your ability to effectively use AI within your applications?",
    options: [
      { id: 'positive', label: "Positively (Enabler)", score: 10 },
      { id: 'neutral', label: "No impact", score: 5 },
      { id: 'negative', label: "Negatively (Blocker)", score: 0 }
    ]
  },
  {
    id: 's_ai_infra',
    category: 'AI Readiness',
    question: "Is your current infrastructure sufficient to meet your primary AI development needs?",
    options: [
      { id: 'sufficient', label: "Sufficient", score: 10 },
      { id: 'insufficient', label: "Insufficient", score: 0 }
    ]
  }
];

const RECOMMENDATIONS = {
  leader: {
    title: "Visionary Leader",
    description: "You are ahead of the curve. Your focus now is optimization and innovation.",
    messaging: "Since you've already modernized, leverage the **Cloudflare Developer Platform** to build stateful apps at the edge. Use **Workers AI** to run inference on global GPUs and **Vectorize** to embed semantic search without managing infrastructure. Adopt **Durable Objects** for real-time consistency.",
    action: "Deploy **Workers** and **Hyperdrive** to accelerate global data access and AI workloads.",
    ctaLabel: "Deploy Workers",
    ctaLink: "https://developers.cloudflare.com/"
  },
  average: {
    title: "Modernization in Progress",
    description: "You are on par with the market, but complexity is likely slowing you down.",
    messaging: "You are making progress, but likely facing 'tool sprawl.' Moving to a unified **Connectivity Cloud** can accelerate your shift from 'On Schedule' to 'Ahead'. Consolidate **DNS**, **Load Balancing**, and **Access** controls into a single control plane.",
    action: "Audit your stack for redundant security vendors (WAF, DDoS, Bot Management).",
    ctaLabel: "Sign up for Cloudflare Test Drive",
    ctaLink: "https://www.cloudflare.com/resource-hub/test-drive/"
  },
  laggard: {
    title: "Modernization Laggard",
    description: "You are falling behind peers, likely due to legacy debt and fractured decision making.",
    messaging: "Your current infrastructure is a bottleneck. Establish a secure foundation with **Core Application Services**. Enable **WAF**, **Global CDN**, and **Unmetered DDoS Protection** to instantly secure legacy apps. For new projects, use **Cloudflare Pages** to deploy static sites instantly.",
    action: "Prioritize decoupling security from legacy hardware using **Cloudflare Connectivity Cloud**.",
    ctaLabel: "Sign up for Cloudflare Test Drive",
    ctaLink: "https://www.cloudflare.com/resource-hub/test-drive/"
  }
};

/**
 * REUSABLE COMPONENTS
 */

const ProgressBar = ({ current, total }) => (
  <div className="w-full bg-gray-200 h-2 rounded-full mb-6">
    <div 
      className="bg-orange-500 h-2 rounded-full transition-all duration-500 ease-out" 
      style={{ width: `${((current + 1) / total) * 100}%` }}
    />
  </div>
);

const BenchmarkChart = ({ label, userValue, leaderValue, userLabel, leaderLabel = "Leaders (Top 13%)" }) => (
  <div className="mb-6">
    <div className="flex justify-between text-sm text-gray-600 mb-1 font-medium">
      <span>{label}</span>
    </div>
    <div className="relative h-8 bg-gray-100 rounded-md overflow-hidden flex items-center">
      <div 
        className="absolute h-full border-r-2 border-gray-400 border-dashed z-10 opacity-50"
        style={{ left: `${leaderValue}%` }}
      />
      <div 
        className={`h-full flex items-center justify-end px-2 text-xs font-bold text-white transition-all duration-1000 ${userValue >= leaderValue ? 'bg-green-500' : 'bg-orange-500'}`}
        style={{ width: `${userValue}%` }}
      >
        {userLabel}
      </div>
    </div>
    <div className="flex justify-between text-xs text-gray-500 mt-1">
      <span>Your Organization</span>
      <span>Target: {leaderLabel} ({leaderValue}%)</span>
    </div>
  </div>
);

/**
 * MAIN APP
 */
export default function App() {
  const [started, setStarted] = useState(false);
  const [currentQ, setCurrentQ] = useState(0);
  const [answers, setAnswers] = useState({});
  const [finished, setFinished] = useState(false);
  const [animating, setAnimating] = useState(false);
  const [reportUnlocked, setReportUnlocked] = useState(false);

  const userProfile = answers['s_mod_perception']?.value || 'average';

  const handleAnswer = (option) => {
    setAnswers(prev => ({ ...prev, [QUESTIONS[currentQ].id]: option }));
    setAnimating(true);
    setTimeout(() => {
      if (currentQ < QUESTIONS.length - 1) {
        setCurrentQ(prev => prev + 1);
        setAnimating(false);
      } else {
        setFinished(true);
        setAnimating(false);
      }
    }, 400);
  };

  const handleDownloadClick = () => {
    setReportUnlocked(true);
    setTimeout(() => window.print(), 300);
  };

  /**
   * VIEW: LANDING
   */
  if (!started) {
    return (
      <div className="min-h-screen bg-white font-sans text-gray-900 flex flex-col items-center justify-center p-6 relative overflow-hidden">
        <div className="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-orange-500 to-yellow-400" />
        <div className="max-w-2xl text-center z-10">
          <div className="mb-6 flex justify-center">
             <div className="h-16 w-16 bg-orange-100 rounded-full flex items-center justify-center text-orange-600">
                <Layers size={32} />
             </div>
          </div>
          <h1 className="text-4xl md:text-5xl font-bold mb-6 tracking-tight">
            App Infrastructure <br/>
            <span className="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-yellow-500">
              Modernization Assessment
            </span>
          </h1>
          <p className="text-lg text-gray-700 mb-6 leading-relaxed">
            The enterprise app infrastructure stack is being rewritten. In the last year, we saw a decisive shift: organizations are redesigning their app infrastructure around platforms that can deliver security, performance and AI at a global scale closest to their users for existing and net new apps.
          </p>
          <p className="text-xl text-gray-600 mb-8 leading-relaxed font-semibold">
            Are you a Leader or a Laggard? Benchmark your infrastructure readiness against 
            industry peers and discover the gaps holding back your modernization efforts.
          </p>
          <button 
            onClick={() => setStarted(true)}
            className="group bg-black text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-orange-600 transition-all flex items-center gap-3 mx-auto shadow-lg"
          >
            Start Assessment <ArrowRight />
          </button>
        </div>
      </div>
    );
  }

  /**
   * VIEW: QUESTION FLOW
   */
  if (started && !finished) {
    const question = QUESTIONS[currentQ];
    return (
      <div className={`min-h-screen bg-gray-50 flex flex-col transition-opacity duration-300 ${animating ? 'opacity-50' : 'opacity-100'}`}>
        <div className="bg-white px-6 py-4 border-b border-gray-200">
          <div className="max-w-2xl mx-auto">
            <div className="flex justify-between text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">
               <span>{question.category}</span>
               <span>Question {currentQ + 1} of {QUESTIONS.length}</span>
            </div>
            <ProgressBar current={currentQ} total={QUESTIONS.length} />
          </div>
        </div>
        <div className="flex-1 flex flex-col items-center justify-center p-6">
          <div className="max-w-2xl w-full">
            <h2 className="text-2xl md:text-3xl font-bold text-gray-900 mb-8 leading-tight">
              {question.question}
            </h2>
            <div className="space-y-4">
              {question.options.map((opt) => (
                <div 
                  key={opt.label}
                  onClick={() => handleAnswer(opt)}
                  className="p-6 rounded-xl border-2 border-gray-200 bg-white hover:border-orange-300 cursor-pointer transition-all flex justify-between items-center group"
                >
                  <span className="font-medium text-lg text-gray-700 group-hover:text-orange-600">{opt.label}</span>
                  <ChevronRight className="text-gray-300 group-hover:text-orange-500" />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    );
  }

  /**
   * VIEW: RESULTS
   */
  const profile = RECOMMENDATIONS[userProfile];
  const isSecurityAligned = (answers['s_sec_difficulty']?.score || 0) >= 5;
  const isAiReady = (answers['s_ai_infra']?.score || 0) >= 10;
  const isConsolidated = (answers['s_techstack_effort']?.score || 0) >= 5;

  return (
    <div className="min-h-screen bg-gray-50 font-sans text-gray-900 pb-20">
      <style>{`
        @media print {
          body * { visibility: hidden; }
          #printable-report, #printable-report * { visibility: visible; }
          #printable-report { position: absolute; left: 0; top: 0; width: 100%; }
          .no-print { display: none !important; }
        }
      `}</style>
      
      <header className="bg-white border-b border-gray-200 p-4 sticky top-0 z-50 no-print">
        <div className="max-w-4xl mx-auto flex justify-between items-center">
          <h2 className="font-bold text-lg">Modernization Assessment</h2>
          {reportUnlocked && (
            <button onClick={() => window.print()} className="flex items-center gap-2 text-orange-600 font-semibold">
              <Download size={18} /> Print Report
            </button>
          )}
        </div>
      </header>

      <main id="printable-report" className="max-w-4xl mx-auto p-6 md:p-10">
        {/* TOP LEVEL VERDICT */}
        <div className="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-8">
          <div className={`p-8 text-white ${userProfile === 'leader' ? 'bg-black' : userProfile === 'laggard' ? 'bg-red-600' : 'bg-orange-500'}`}>
            <h1 className="text-4xl font-bold mb-4">{profile.title}</h1>
            <p className="text-lg opacity-90">{profile.description}</p>
          </div>
          <div className="p-8">
            <h3 className="text-xl font-bold mb-4 text-gray-800">The Verdict</h3>
            <p className="text-gray-600 mb-6 leading-relaxed">
              {profile.messaging.split('**').map((p, i) => i % 2 === 1 ? <strong key={i}>{p}</strong> : p)}
            </p>
            <div className="bg-orange-50 border-l-4 border-orange-500 p-4 rounded-r-lg">
              <h4 className="font-bold text-orange-800 mb-1 flex items-center gap-2"><Zap size={18}/> Recommended Action:</h4>
              <p className="text-orange-900">{profile.action}</p>
            </div>
          </div>
        </div>

        {!reportUnlocked ? (
          <div className="bg-white p-8 rounded-2xl border border-gray-200 shadow-sm text-center no-print">
            <h3 className="text-2xl font-bold mb-3">Unlock Detailed Analysis</h3>
            <p className="text-gray-600 mb-8 max-w-lg mx-auto">Get a comprehensive PDF report including peer benchmarks and gap analysis.</p>
            <div className="flex flex-col items-center gap-6">
              <button onClick={handleDownloadClick} className="bg-orange-500 text-white px-8 py-4 rounded-xl font-bold text-lg shadow-lg flex items-center gap-3">
                <Download /> Download Detailed Assessment
              </button>
              <a href="https://www.cloudflare.com/resource-hub/test-drive/" className="text-gray-500 font-medium flex items-center gap-2 text-sm">
                Sign up for Cloudflare Test Drive <ArrowRight size={14}/>
              </a>
            </div>
          </div>
        ) : (
          <div className="animate-in fade-in duration-700">
            <h2 className="text-2xl font-bold mb-6 mt-12">Peer Benchmark & Gap Analysis</h2>
            <div className="grid md:grid-cols-2 gap-6 mb-12">
              {/* SECURITY */}
              <div className="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
                <div className="flex items-center gap-3 mb-4">
                  <Shield className="text-blue-600" /> <h3 className="font-bold">Security Alignment</h3>
                </div>
                <BenchmarkChart label="Alignment Score" userValue={isSecurityAligned ? 95 : 30} userLabel={isSecurityAligned ? "Aligned" : "Difficulty"} leaderValue={71} />
                <div className="text-sm bg-gray-50 p-3 rounded mb-4">
                  {isSecurityAligned ? "Aligned with Leaders." : "Gap Detected. Fragmented tools hinder speed."}
                </div>
                <div className="pt-4 border-t border-gray-100">
                  <a href={isSecurityAligned ? "https://www.cloudflare.com/the-net/security-by-design/" : "https://www.cloudflare.com/the-net/year-in-review-25/"} className="text-orange-600 font-bold text-sm flex items-center gap-2">
                    {isSecurityAligned ? "Building Trust with Security by Design" : "2025 Security Year in Review"} <ArrowRight size={14} />
                  </a>
                </div>
              </div>

              {/* AI */}
              <div className="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
                <div className="flex items-center gap-3 mb-4">
                  <Layout className="text-purple-600" /> <h3 className="font-bold">AI Readiness</h3>
                </div>
                <BenchmarkChart label="Infra Sufficiency" userValue={isAiReady ? 96 : 40} userLabel={isAiReady ? "Ready" : "Insufficient"} leaderValue={96} />
                <div className="text-sm bg-gray-50 p-3 rounded mb-4">
                  {isAiReady ? "Your infrastructure is ready for edge inference." : "Legacy clouds create latency bottlenecks."}
                </div>
                <div className="pt-4 border-t border-gray-100">
                  <a href={isAiReady ? "https://www.cloudflare.com/the-net/risk-reward-ai/" : "https://www.cloudflare.com/the-net/modernize-applications/"} className="text-orange-600 font-bold text-sm flex items-center gap-2">
                    {isAiReady ? "Navigating the Risks and Rewards of AI" : "A Blueprint for Modernizing Applications"} <ArrowRight size={14} />
                  </a>
                </div>
              </div>

              {/* CONSOLIDATION */}
              <div className="bg-white p-6 rounded-xl border border-gray-200 shadow-sm md:col-span-2">
                <div className="flex items-center gap-3 mb-4">
                  <RefreshCw className="text-green-600" /> <h3 className="font-bold">Consolidation</h3>
                </div>
                <BenchmarkChart label="Effort Level" userValue={isConsolidated ? 90 : 20} userLabel={isConsolidated ? "High Effort" : "Low Effort"} leaderValue={85} />
                <div className="text-sm bg-gray-50 p-3 rounded mb-4">
                  {isConsolidated ? "Rightly focused on unification." : "Accumulating technical debt via tool sprawl."}
                </div>
                <div className="pt-4 border-t border-gray-100">
                  <a href={isConsolidated ? "https://blog.cloudflare.com/connectivity-cloud/" : "https://www.cloudflare.com/the-net/how-to-scale-apps-globally/"} className="text-orange-600 font-bold text-sm flex items-center gap-2">
                    {isConsolidated ? "Delivering on the Promise of a Connectivity Cloud" : "How to Scale Applications Globally"} <ArrowRight size={14} />
                  </a>
                </div>
              </div>
            </div>
            
            <div className="bg-gray-900 text-white rounded-2xl p-8 text-center no-print">
              <h3 className="text-2xl font-bold mb-4">Close the Gap with Cloudflare</h3>
              <p className="text-gray-400 mb-8 max-w-2xl mx-auto">Don't let legacy vendors dictate your roadmap. Move to the Connectivity Cloud.</p>
              <button onClick={() => window.open(profile.ctaLink, '_blank')} className="bg-orange-500 text-white px-6 py-3 rounded-lg font-bold">
                {profile.ctaLabel}
              </button>
            </div>
          </div>
        )}
      </main>
    </div>
  );
}
